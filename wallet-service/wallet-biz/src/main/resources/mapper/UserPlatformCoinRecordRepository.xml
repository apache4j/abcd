    <select id="winLoseRecalculateMainPage"
            resultType="com.cloud.baowang.wallet.api.vo.report.WinLoseRecalculateWalletVO">
        select
        a.site_code as siteCode,
        a.user_id as userId,
        a.user_account as userAccount,
        a.agent_id as agentId,
        a.agent_name as superAgentAccount,
        b.main_currency as mainCurrency,
        SUM(case when(a.business_coin_type) in ('2','3') then a.coin_to-a.coin_from    end) as activityAmount,
        sum(case when(a.business_coin_type) in( '1') then a.coin_to-a.coin_from    end) as vipAmount,
        /*sum(case when(a.business_coin_type) in( '5') then a.coin_to-a.coin_from    end) as rebateAmount,*/
        sum(case when(a.business_coin_type) in( '6') then a.coin_to-a.coin_from    end) as platAdjustAmount,
        ANY_VALUE(b.account_type) AS accountType
        from user_platform_coin_record a left join user_info b
        on a.user_id = b.user_id
        where a.created_time <![CDATA[ >= ]]> #{vo.startTime}
        and a.created_time <![CDATA[ <= ]]> #{vo.endTime}
        <if test="vo.siteCode != null and vo.siteCode !=''">
            and a.site_code = #{vo.siteCode}
        </if>
        <if test="vo.businessType != null and !vo.businessType.isEmpty()">
            AND a.business_coin_type IN
            <foreach collection="vo.businessType" item="value" separator="," open="(" close=")">
                #{value}
            </foreach>
        </if>

        group by
        a.site_code,a.user_id,a.user_account,b.main_currency,a.agent_id,a.agent_name
        order by
        a.site_code,a.user_id,a.user_account,b.main_currency,a.agent_id,a.agent_name
    </select>

</mapper>
