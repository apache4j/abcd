<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cloud.baowang.wallet.repositories.UserPlatformCoinRecordRepository">

    <select id="sumUserPlatformCoinRecord" resultType="com.cloud.baowang.wallet.api.vo.userCoinRecord.UserPlatformCoinRecordVO">
        SELECT
            "总计" AS orderNo,
            IFNULL(SUM(a.coin_from),0) AS coinFrom,
            IFNULL(SUM(a.coin_value),0) AS coinValue,
            IFNULL(SUM(a.coin_to),0) AS coinTo
        FROM
            user_platform_coin_record a
        WHERE
            a.site_code = #{vo.siteCode}
        <if test="vo.coinRecordStartTime != null">
            AND a.created_time &gt;= #{vo.coinRecordStartTime}
        </if>
        <if test="vo.coinRecordEndTime != null">
            AND a.created_time &lt;= #{vo.coinRecordEndTime}
        </if>
        <if test="vo.orderNo != null and vo.orderNo !=''">
            AND a.order_no = #{vo.orderNo}
        </if>
        <if test="vo.currencyCode != null and vo.currencyCode !=''">
            AND a.currency = #{vo.currencyCode}
        </if>
        <if test="vo.userAccount != null and vo.userAccount !=''">
            AND a.user_account = #{vo.userAccount}
        </if>
        <if test="vo.accountStatus != null and vo.accountStatus !=''">
            AND a.account_status = #{vo.accountStatus}
        </if>
        <if test="vo.riskLevelId != null and vo.riskLevelId !=''">
            AND a.risk_control_level_id = #{vo.riskLevelId}
        </if>
        <if test="vo.minVipRank != null and vo.minVipRank !=''">
            AND a.vip_rank &gt;= #{vo.minVipRank}
        </if>
        <if test="vo.maxVipRank != null and vo.maxVipRank !=''">
            AND a.vip_rank &lt;= #{vo.maxVipRank}
        </if>
        <if test="vo.minVipGradeCode != null and vo.minVipGradeCode !=''">
            AND a.vip_grade_code &gt;= #{vo.minVipGradeCode}
        </if>
        <if test="vo.maxVipGradeCode != null and vo.maxVipGradeCode !=''">
            AND a.vip_grade_code &lt;= #{vo.maxVipGradeCode}
        </if>
        <if test="vo.businessCoinType != null and vo.businessCoinType !=''">
            AND a.business_coin_type = #{vo.businessCoinType}
        </if>
        <if test="vo.coinType != null and vo.coinType !='' ">
            AND a.coin_type = #{vo.coinType}
        </if>
        <if test="vo.balanceType != null and vo.balanceType !=''">
            AND a.balance_type = #{vo.balanceType}
        </if>
        <if test="vo.businessCoinTypeList != null and vo.businessCoinTypeList.size > 0">
            AND a.business_coin_type IN
            <foreach collection="vo.businessCoinTypeList" item="value" separator="," open="(" close=")">
                #{value}
            </foreach>
        </if>
        <if test="vo.coinTypeList != null  and vo.coinTypeList.size > 0">
            AND a.coin_type IN
            <foreach collection="vo.coinTypeList" item="value" separator="," open="(" close=")">
                #{value}
            </foreach>
        </if>

        <if test="vo.minCoinValue != null ">
            AND a.coin_value &gt;= #{vo.minCoinValue}
        </if>
        <if test="vo.maxCoinValue != null ">
            AND a.coin_value &lt;= #{vo.maxCoinValue}
        </if>

    </select>
